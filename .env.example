# PolyBot - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# =============================================================================
# REQUIRED: Real-Time Data Connections
# =============================================================================

# The Graph API Key (Required for Polymarket data indexing)
# Get from: https://thegraph.com/studio/apikeys/
# This provides access to historical trades, markets, and user data
THEGRAPH_API_KEY=cfcfe34e440379a8b57d8a769a66bc00
# =============================================================================
# REQUIRED: Polygon Blockchain Connection
# =============================================================================
# OPTION A: Alchemy (Recommended - more reliable, better WebSocket support)
# Sign up: https://www.alchemy.com/
# Create a Polygon Mainnet app and copy the API key
ALCHEMY_API_KEY=_ji9dYogsSdrCR6fv--TA

# Alchemy endpoints (auto-generated from API key)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/_ji9dYogsSdrCR6fv--TA
POLYGON_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/_ji9dYogsSdrCR6fv--TA

# OPTION B: Public RPC (Free but less reliable, rate-limited)
# Uncomment these if not using Alchemy:
# POLYGON_RPC_URL=https://polygon-rpc.com
# POLYGON_WS_URL=wss://polygon-mainnet.public.blastapi.io

# =============================================================================
# REQUIRED: Polymarket CLOB API (for orderbook and trading)
# =============================================================================
# Get from: https://polymarket.com/settings/api
# Required for real-time orderbook data and live trading
POLYMARKET_API_KEY=019c0f80-06f3-7612-b479-378c2ec4bf7b
POLYMARKET_API_SECRET=your_polymarket_api_secret

# =============================================================================
# OPTIONAL: Backup RPC Providers
# =============================================================================

# Infura (alternative RPC provider)
# Get from: https://www.infura.io/
INFURA_API_KEY=your_infura_api_key
# INFURA_POLYGON_RPC=https://polygon-mainnet.infura.io/v3/your_infura_api_key

# =============================================================================
# OPTIONAL: Real-Time Data Settings
# =============================================================================

# WebSocket connection settings
WS_RECONNECT_INTERVAL=5                 # Seconds between reconnection attempts
WS_MAX_RECONNECT_ATTEMPTS=10            # Maximum reconnection attempts
WS_PING_INTERVAL=30                     # Seconds between keepalive pings

# RPC failover settings
RPC_FAILOVER_ENABLED=true               # Enable automatic failover to backup RPCs
RPC_TIMEOUT_SECONDS=10                  # Request timeout
RPC_RETRY_ATTEMPTS=3                    # Retry attempts per endpoint

# Data refresh intervals (seconds)
MARKET_DATA_REFRESH_INTERVAL=5          # Market metadata refresh
ORDERBOOK_REFRESH_INTERVAL=1            # Orderbook update interval
TRADE_HISTORY_REFRESH_INTERVAL=2        # Trade history poll interval
PRICE_FEED_REFRESH_INTERVAL=3           # Price feed update interval

# =============================================================================
# OPTIONAL: Live Trading (WARNING: Uses real money when enabled)
# =============================================================================

# Enable Live Trading Mode (false = paper trading only)
# WARNING: Setting to true uses REAL MONEY - start with paper trading!
LIVE_TRADING_ENABLED=false

# Starting balance for paper trading (USD)
PAPER_TRADE_BALANCE_USD=10000

# Default paper trade size (USD)
PAPER_TRADE_SIZE_USD=100

# =============================================================================
# OPTIONAL: Whale Tracking Configuration
# =============================================================================

# Tracking Mode: realtime or scheduled
TRACKING_MODE=realtime

# Specific whale addresses to track (comma-separated, no spaces)
# Example: 0x123...,0x456...,0x789...
# If empty, bot will auto-discover whales from recent activity
WHALE_ADDRESSES=

# Crypto-only filtering (track only crypto-related markets)
CRYPTO_ONLY=true

# Polling interval in seconds for scheduled mode (default: 30)
POLL_INTERVAL_SECONDS=30

# Maximum delay to copy after whale trade (seconds)
MAX_DELAY_TO_COPY_SECONDS=60

# Minimum pattern confidence to copy (0.0 - 1.0)
MIN_PATTERN_CONFIDENCE=0.7

# Minimum whale trade size to consider (USD)
MIN_WHALE_USD=5000

# Whale discovery settings
WHALE_DISCOVERY_ENABLED=true            # Auto-discover new whales
WHALE_DISCOVERY_MIN_VOLUME=100000       # Min volume to be considered whale
WHALE_DISCOVERY_MIN_TRADES=10           # Min trades to be considered
WHALE_DISCOVERY_DAYS=30                 # Lookback period for discovery

# Copy speed matching: aggressive, moderate, conservative
COPY_SPEED_MATCHING=moderate

# Log timing metrics for analysis
LOG_TIMING_METRICS=true

# Real-time alert settings
REALTIME_ALERTS_ENABLED=true
ALERT_ON_LARGE_TRADES=true
ALERT_ON_WHALE_ACCUMULATION=true
ALERT_ON_PRICE_MOVES=true

# =============================================================================
# OPTIONAL: Risk Management
# =============================================================================

# Max risk per trade (% of bankroll)
MAX_RISK_PER_TRADE=0.02

# Max portfolio heat (% of bankroll in open positions)
MAX_PORTFOLIO_HEAT=0.50

# Max concurrent positions
MAX_OPEN_POSITIONS=5

# Daily drawdown circuit breaker (%)
MAX_DAILY_DRAWDOWN=0.10

# Max position size (USD)
MAX_POSITION_SIZE=500

# Min position size (USD)
MIN_POSITION_SIZE=50

# =============================================================================
# OPTIONAL: Notifications
# =============================================================================

# Discord Webhook for notifications
# Create webhook in Discord channel settings
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Telegram Bot for notifications
# Create bot via @BotFather, then get chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Notification Settings
NOTIFICATION_RATE_LIMIT=30              # Max notifications per minute
NOTIFICATION_COOLDOWN_SECONDS=60        # Cooldown between same-type notifications
NOTIFICATION_ENABLED=true

# =============================================================================
# OPTIONAL: Automation Schedule
# =============================================================================

# Daily scan time (24h format)
SCHEDULE_SCAN_TIME=09:00

# Daily report time (24h format)
SCHEDULE_REPORT_TIME=18:00

# Enable automated daily workflow
SCHEDULE_ENABLED=false

# =============================================================================
# OPTIONAL: Backtesting
# =============================================================================

# Default backtest days
BACKTEST_DEFAULT_DAYS=30

# Default initial capital for backtests
BACKTEST_INITIAL_CAPITAL=10000

# Data source: subgraph, database, csv
BACKTEST_DATA_SOURCE=database

# =============================================================================
# OPTIONAL: Database
# =============================================================================

# Database file path (SQLite)
DATABASE_PATH=./data/polybot.db

# Cache expiry (hours)
MARKET_CACHE_HOURS=1                    # Reduced for real-time data
REALTIME_CACHE_SECONDS=30               # Cache for real-time feeds

# Event log retention (days)
EVENT_LOG_RETENTION_DAYS=90

# Database connection pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# =============================================================================
# OPTIONAL: Analytics
# =============================================================================

# Performance report interval (days)
ANALYTICS_REPORT_INTERVAL=1

# Enable detailed analytics logging
ANALYTICS_DETAILED=false

# Export analytics to CSV
ANALYTICS_EXPORT_CSV=true

# =============================================================================
# OPTIONAL: Development/Debug
# =============================================================================

# Debug mode (verbose logging)
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/polybot.log

# Test mode (uses mock data, no real connections)
TEST_MODE=false

# =============================================================================
# LEGACY: Additional Services (Future Use)
# =============================================================================

# OpenAI API Key (for LLM features - future use)
OPENAI_API_KEY=your_openai_api_key

# Redis (for caching - future use)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (alternative to SQLite - future use)
POSTGRES_URL=postgresql://user:password@localhost:5432/polybot
